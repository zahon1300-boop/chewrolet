# ============================================================
# .env.example — Muhit o'zgaruvchilari namunasi
# Haqiqiy foydalanish uchun bu faylni ".env" nomi bilan nusxalang
# va qiymatlarni o'zgartiring.
# ============================================================

# Django
DJANGO_SECRET_KEY=your-very-secret-key-here-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Production PostgreSQL (USE_POSTGRES=True bo'lganda)
USE_POSTGRES=False
DB_NAME=chevrolet_uz_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Log darajasi
DJANGO_LOG_LEVEL=INFO
